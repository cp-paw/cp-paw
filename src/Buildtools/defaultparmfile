  export INTELDIR=${FC%/bin/*}
  # -mkl=sequential is deprecated option. shall we use -qmkl=sequential instead?
  LDFLAGS="${LDFLAGS} -Wl,-dn -mkl=sequential -Wl,-dy"

  # this rule for fftw3xf_intel is probably not required. 
