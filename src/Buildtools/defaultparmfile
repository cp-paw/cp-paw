# CUDA is used here as a hardware/toolchain signal for NVIDIA HPC SDK builds.
# CP-PAW has no CUDA Fortran kernels by default, so CUDA code generation is
# opt-in to avoid an unnecessary CUDA runtime dependency for CPU-only binaries.
if [[ ${COMPILER} = nvfortran \
      && ( ${CPPAW_USE_CUDA_FORTRAN:-no} = yes \
           || ${CPPAW_USE_CUDA_FORTRAN:-no} = true ) ]] ; then
  if [[ ${CPPAW_CUDA_AVAILABLE} != true ]] ; then
    echo "error in $0: CPPAW_USE_CUDA_FORTRAN requested but CUDA was not found"
    exit 1
  fi
  CUDA_FORTRAN_FLAGS="-cuda"
  if [[ -n ${CPPAW_CUDA_CC} ]] ; then
    CUDA_FORTRAN_FLAGS="${CUDA_FORTRAN_FLAGS} -gpu=cc${CPPAW_CUDA_CC}"
  fi
  FCFLAGS="${FCFLAGS} ${CUDA_FORTRAN_FLAGS}"
  LDFLAGS="${LDFLAGS} ${CUDA_FORTRAN_FLAGS}"
fi

